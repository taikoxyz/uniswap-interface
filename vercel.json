{
  "buildCommand": "yarn build",
  "devCommand": "yarn start",
  "installCommand": "yarn install --ignore-engines --network-timeout 100000",
  "framework": null,
  "outputDirectory": "build",
  "env": {
    "NODE_VERSION": "20.x"
  },
  "headers": [
    {
      "source": "/widget",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *;"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
